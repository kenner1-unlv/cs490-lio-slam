[Unit]
Description=RDK X5 LC29H GPS ROS2 Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sunrise
WorkingDirectory=/home/sunrise
Environment=RMW_IMPLEMENTATION=rmw_fastrtps_cpp
Environment=ROS_DOMAIN_ID=0
ExecStart=/bin/bash -lc 'source /opt/ros/humble/setup.bash && exec python3 /home/sunrise/gps_bridge/rdk_gps_node.py'
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
