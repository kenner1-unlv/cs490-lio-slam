[Unit]
Description=RDK X5 ToF and Ultrasonic ROS2 Range Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=sunrise
WorkingDirectory=/home/sunrise
Environment=ROS_DOMAIN_ID=0
Environment=RMW_IMPLEMENTATION=rmw_fastrtps_cpp
ExecStart=/bin/bash -lc 'source /opt/tros/humble/setup.bash 2>/dev/null || source /opt/ros/humble/setup.bash; exec python3 /home/sunrise/tof_bridge.py'
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
